{
  "name": "tapnow-studio",
  "private": true,
  "version": "3.8.8-rc7",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "desktop:dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron .\"",
    "desktop:build:sidecar": "python scripts/build-localserver-sidecar.py",
    "desktop:pack": "vite build --mode desktop && electron-builder --dir",
    "desktop:build": "vite build --mode desktop && electron-builder --win --x64",
    "build": "vite build && node scripts/copy-versioned-build.cjs",
    "release:windows": "npm run build && node scripts/package-windows-portable.cjs",
    "preview": "vite preview",
    "test:k87": "node scripts/k87_feature_tests.cjs",
    "test:storyboard-parser": "node scripts/storyboard_project_parser_regression.cjs",
    "test:storyboard-roundtrip": "node scripts/storyboard_save_load_roundtrip_regression.cjs",
    "test:smoke-playwright": "node scripts/smoke_playwright_fallback.cjs",
    "test:mcp-gateway": "node scripts/mcp_gateway_smoke.cjs",
    "test:mcp-frontend": "node scripts/mcp_frontend_tools_smoke.cjs",
    "test:release:gates": "npm run test:k87 && npm run test:storyboard-parser && npm run test:storyboard-roundtrip && npm run test:mcp-gateway && npm run test:mcp-frontend"
  },
  "build": {
    "appId": "studio.tapnow.desktop",
    "productName": "Tapnow Studio",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "localserver",
        "to": "localserver",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dist-sidecar",
        "to": "localserver-sidecar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "dompurify": "^3.0.8",
    "file-saver": "^2.0.5",
    "i18next": "^23.12.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "marked": "^12.0.0",
    "openai": "^6.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.1.3",
    "three": "^0.177.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "playwright-core": "^1.58.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "wait-on": "^9.0.3",
    "vite-plugin-singlefile": "^2.0.1"
  }
}
